font-family = Monaco
font-size = 12

theme = Ayu Mirage
window-colorspace = display-p3
background = 1f1f28

cursor-style = block
cursor-style-blink = true
cursor-color = e66b2a

macos-titlebar-style = hidden
window-padding-x = 8
window-padding-y = 4

# Make Shift+Enter insert a newline in terminal TUIs
keybind = shift+enter=text:\n
